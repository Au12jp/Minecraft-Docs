{
  "$id": "4283276213",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "2036701363": {
      "oneOf": [
        {
          "items": {
            "pattern": "^\\S+$",
            "type": "string"
          },
          "type": "array"
        },
        {
          "pattern": "^\\S+$",
          "type": "string"
        }
      ],
      "title": "Server Sound Tag Value List"
    },
    "2103472662": {
      "description": "Server-authoritative duration metadata. When present, the server tracks the sound's lifetime.",
      "properties": {
        "mode": {
          "description": "How the duration drains: \"game_time\" decrements by tick, \"real_time\" decrements by wall-clock time.",
          "enum": [
            "game_time",
            "real_time"
          ],
          "title": "Server Sound Duration Mode",
          "type": "string"
        },
        "seconds": {
          "description": "Duration in seconds.",
          "type": "number"
        }
      },
      "required": [
        "mode",
        "seconds"
      ],
      "title": "Server Sound Duration Info",
      "type": "object"
    },
    "507846529": {
      "description": "Optional music metadata describing the sound.",
      "properties": {
        "artist": {
          "description": "Artist name. Authored either as literal display text or as a translation key.",
          "type": "string"
        },
        "genres": {
          "description": "Free-form genre labels.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "moods": {
          "description": "Free-form mood labels.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "description": "Display title for the track. Authored either as literal display text or as a translation key.",
          "type": "string"
        }
      },
      "title": "Server Sound Music Info",
      "type": "object"
    }
  },
  "description": "A single server-authoritative sound definition.",
  "properties": {
    "duration_info": {
      "$ref": "#/definitions/2103472662",
      "description": "Optional server-authoritative duration metadata."
    },
    "music_info": {
      "$ref": "#/definitions/507846529",
      "description": "Optional music metadata."
    },
    "sound_event_name": {
      "description": "The namespaced sound event ID used to play this sound.",
      "pattern": "^\\S+$",
      "type": "string",
      "x-regex-flags": "ECMAScript,icase"
    },
    "tags": {
      "additionalProperties": {
        "$ref": "#/definitions/2036701363"
      },
      "description": "Optional pack-defined key-value tags. Each value may be a single string or an array of strings.",
      "propertyNames": {
        "pattern": "^\\S+$",
        "type": "string"
      },
      "type": "object"
    }
  },
  "required": [
    "sound_event_name"
  ],
